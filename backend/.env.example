# ── Local development ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values

# PostgreSQL connection string
# Local: use this format after installing Postgres on your PC
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/expensetrack

# Railway (production): copy the DATABASE_URL from Railway dashboard
# DATABASE_URL=postgresql://postgres:xxxx@containers-us-west-xxx.railway.app:5432/railway

# JWT secret — change this to any long random string
JWT_SECRET=replace-this-with-a-long-random-secret-string

# Frontend URL (used for CORS)
FRONTEND_URL=http://localhost:5173

# Set to 'production' when deploying
NODE_ENV=development
